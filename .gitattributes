# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.pyc binary
*.pyo binary
*.egg binary
*.so binary
*.o binary
*.a binary
*.dylib binary
*.dll binary
*.exe binary
*.zip binary
*.tar binary
*.gz binary

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.svg binary
*.ico binary
*.webp binary
